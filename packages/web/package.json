{
  "name": "@workerhub-mcp/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n ui,api -c green,blue \"vite\" \"tsx watch server/host.ts\"",
    "dev:ui": "vite",
    "dev:api": "tsx watch server/host.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start:api": "node dist-server/host.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@workerhub-mcp/app": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
